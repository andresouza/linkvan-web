# Base URL of the LinkVan API (used by the frontend fetcher). No trailing slash.
NEXT_PUBLIC_BACKEND_URL="https://linkvan.api.url"

# Google Analytics measurement ID (e.g. G-XXXXXXXXXX). Optional; omit to disable GA.
NEXT_PUBLIC_GOOGLE_ANALYTICS="G-XXXXXXXXXX"

# Google Maps JavaScript API key (Maps JavaScript API enabled for the app).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSyBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
